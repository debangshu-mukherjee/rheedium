{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rheedium.local/schema/recipe_deviation_report.v1.json",
  "title": "Rheedium Recipe Deviation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "severity",
    "max_abs_z",
    "thresholds",
    "uncertainty",
    "solver",
    "parameters"
  ],
  "properties": {
    "schema_version": {
      "const": "recipe-deviation-report.v1"
    },
    "severity": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "max_abs_z": {
      "type": "number"
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warning_z", "critical_z"],
      "properties": {
        "warning_z": {"type": "number"},
        "critical_z": {"type": "number"}
      }
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "standard_deviation", "covariance"],
      "properties": {
        "source": {
          "enum": ["laplace", "supplied"]
        },
        "standard_deviation": {
          "type": "array",
          "items": {"type": "number"}
        },
        "covariance": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "number"}
          }
        }
      }
    },
    "solver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["converged", "iterations", "loss", "status"],
      "properties": {
        "converged": {"type": "boolean"},
        "iterations": {"type": "integer", "minimum": 0},
        "loss": {"type": "number"},
        "status": {"type": "string"}
      }
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "intended",
          "fitted",
          "deviation",
          "z_score",
          "standard_deviation"
        ],
        "properties": {
          "name": {"type": "string"},
          "intended": {"type": "number"},
          "fitted": {"type": "number"},
          "deviation": {"type": "number"},
          "z_score": {"type": "number"},
          "standard_deviation": {"type": "number"}
        }
      }
    }
  }
}
